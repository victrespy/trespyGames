{# templates/bundles/TwigBundle/Exception/error404.html.twig #}
{% extends 'base.html.twig' %}

{% set hide_navbar = true %}

{% block title %}404 - Fuera de Mapa{% endblock %}

{% block body %}
    <div class="flex flex-col items-center justify-center min-h-screen text-center px-4">
        <h1 class="text-9xl font-black text-custom-red animate-pulse">404</h1>
        <h2 class="text-3xl font-black text-custom-negro uppercase italic mt-4">¡Te has salido del mapa!</h2>
        <p class="text-custom-negro/70 font-bold mt-2 uppercase tracking-widest text-xs">La zona a la que intentas acceder no existe o ha sido eliminada.</p>

        <div class="mt-10">
            <a href="{{ path('app_home') }}" class="bg-custom-red hover:bg-custom-negro text-custom-crema font-black py-4 px-8 rounded-none transition-all uppercase tracking-widest shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] active:shadow-none active:translate-x-[2px] active:translate-y-[2px]">
                Volver al inicio
            </a>
        </div>
    </div>
{% endblock %}
