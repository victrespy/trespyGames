{# templates/bundles/TwigBundle/Exception/error403.html.twig #}
{% extends 'base.html.twig' %}

{% set hide_navbar = true %}

{% block title %}403 - Acceso Denegado{% endblock %}

{% block body %}
    <div class="flex flex-col items-center justify-center min-h-screen text-center px-4">
        <div class="border-8 border-custom-red p-8 inline-block shadow-[10px_10px_0px_0px_rgba(0,0,0,1)]">
            <h1 class="text-7xl font-black text-custom-red uppercase">Prohibido</h1>
            <h2 class="text-2xl font-black text-custom-negro mt-4 italic">Nivel de acceso insuficiente</h2>
        </div>

        <p class="text-custom-negro font-bold mt-8 uppercase tracking-tighter max-w-md">
            Esta zona está reservada exclusivamente para administradores del club.
            Tu rango actual no permite cruzar esta puerta.
        </p>

        <div class="mt-12 flex gap-4">
            <a href="{{ path('app_home') }}" class="text-custom-red underline font-black uppercase tracking-widest text-sm hover:text-custom-negro">
                Escapar de aquí
            </a>
        </div>
    </div>
{% endblock %}
